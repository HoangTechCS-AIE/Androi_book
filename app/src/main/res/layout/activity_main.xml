<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context=".MainActivity">

    <!-- Top App Bar -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="24dp"
        android:paddingVertical="16dp"
        android:gravity="center_vertical"
        android:background="#ccffffff"
        android:translationZ="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Logo & Title -->
        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/ic_menu_agenda"
            app:tint="@color/primary_container" />

        <TextView
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Book Space"
            android:textSize="24sp"
            android:textStyle="bold|italic"
            android:textColor="@color/primary"
            android:layout_marginStart="8dp"/>

        <!-- Icons -->
        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:padding="4dp"
            android:src="@android:drawable/ic_popup_reminder"
            app:tint="@color/on_surface_variant"/>

        <!-- User Profile Placeholder -->
        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="16dp"
            android:src="@mipmap/ic_launcher_round"/>
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="100dp"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="16dp">

            <!-- Search Bar -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="40dp"
                app:cardCornerRadius="28dp"
                app:cardBackgroundColor="@color/surface_container_highest"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="20dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_search"
                        app:tint="@color/outline" />

                    <EditText
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@null"
                        android:hint="Tìm sách, tên tác giả..."
                        android:textColorHint="@color/outline"
                        android:textColor="@color/on_surface"
                        android:textSize="16sp"
                        android:layout_marginStart="12dp"
                        android:maxLines="1"
                        android:inputType="text"/>
                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Categories -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:layout_marginBottom="48dp"
                android:layout_marginHorizontal="-24dp"
                android:paddingHorizontal="24dp"
                android:clipToPadding="false">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Chips -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/chip_active_bg"
                        android:text="Tất cả"
                        android:textColor="@color/on_primary"
                        android:paddingHorizontal="24dp"
                        android:paddingVertical="10dp"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/chip_bg"
                        android:text="Kỹ năng sống"
                        android:textColor="@color/on_surface_variant"
                        android:paddingHorizontal="24dp"
                        android:paddingVertical="10dp"
                        android:layout_marginStart="12dp"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/chip_bg"
                        android:text="Tâm lý"
                        android:textColor="@color/on_surface_variant"
                        android:paddingHorizontal="24dp"
                        android:paddingVertical="10dp"
                        android:layout_marginStart="12dp"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/chip_bg"
                        android:text="Kinh điển"
                        android:textColor="@color/on_surface_variant"
                        android:paddingHorizontal="24dp"
                        android:paddingVertical="10dp"
                        android:layout_marginStart="12dp"
                        android:textSize="14sp" />
                        
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/chip_bg"
                        android:text="Kinh tế"
                        android:textColor="@color/on_surface_variant"
                        android:paddingHorizontal="24dp"
                        android:paddingVertical="10dp"
                        android:layout_marginStart="12dp"
                        android:textSize="14sp" />
                </LinearLayout>

            </HorizontalScrollView>

            <!-- Featured Section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nổi bật trong tuần"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/on_surface"
                android:layout_marginBottom="24dp"/>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:layout_marginBottom="48dp"
                android:layout_marginHorizontal="-24dp"
                android:paddingHorizontal="24dp"
                android:clipToPadding="false">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Featured Card 1 -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="300dp"
                        android:layout_height="220dp"
                        app:cardCornerRadius="16dp"
                        app:cardBackgroundColor="@color/primary"
                        android:layout_marginEnd="16dp">
                        
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="bottom"
                            android:padding="24dp">
                            
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="EDITOR'S CHOICE"
                                android:textColor="#ccffffff"
                                android:textSize="12sp"
                                android:letterSpacing="0.1"
                                android:layout_marginBottom="8dp"/>
                                
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Nghệ thuật của sự tĩnh lặng"
                                android:textColor="@color/on_primary"
                                android:textSize="24sp"
                                android:textStyle="bold"
                                android:layout_marginBottom="8dp"/>

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Khám phá sức mạnh của việc dừng lại trong một thế giới không bao giờ ngừng nghỉ."
                                android:textColor="#e5ffffff"
                                android:textSize="14sp"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                    
                    <!-- Featured Card 2 -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="300dp"
                        android:layout_height="220dp"
                        app:cardCornerRadius="16dp"
                        app:cardBackgroundColor="@color/tertiary">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="bottom"
                            android:padding="24dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="NEW ARRIVAL"
                                android:textColor="#ccffffff"
                                android:textSize="12sp"
                                android:letterSpacing="0.1"
                                android:layout_marginBottom="8dp"/>

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Hành trình tâm thức"
                                android:textColor="@color/on_tertiary"
                                android:textSize="24sp"
                                android:textStyle="bold"
                                android:layout_marginBottom="8dp"/>

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Một cái nhìn sâu sắc vào tâm lý học."
                                android:textColor="#e5ffffff"
                                android:textSize="14sp"/>
                        </LinearLayout>

                    </androidx.cardview.widget.CardView>
                </LinearLayout>
            </HorizontalScrollView>

            <!-- Recently Updated -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="bottom"
                android:layout_marginBottom="24dp">
                
                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Mới cập nhật"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="@color/on_surface"/>
                    
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Xem tất cả"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary"/>
            </LinearLayout>

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:rowCount="2">
                
                <!-- Book 1 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="12dp"
                    android:layout_marginBottom="24dp">
                    
                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardCornerRadius="8dp"
                        app:cardBackgroundColor="@color/surface_container_low"
                        app:cardElevation="2dp"
                        android:layout_marginBottom="12dp">
                        
                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="180dp"
                            android:scaleType="centerCrop"
                            android:background="@color/surface_container_low"/>
                    </androidx.cardview.widget.CardView>
                    
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Kiêu hãnh và định kiến"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/on_surface"
                        android:maxLines="2"
                        android:layout_marginBottom="4dp"/>
                        
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Jane Austen"
                        android:textSize="14sp"
                        android:textColor="@color/on_surface_variant"/>
                </LinearLayout>

                <!-- Book 2 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp"
                    android:layout_marginBottom="24dp">

                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardCornerRadius="8dp"
                        app:cardBackgroundColor="@color/surface_container_low"
                        app:cardElevation="2dp"
                        android:layout_marginBottom="12dp">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="180dp"
                            android:scaleType="centerCrop"
                            android:background="@color/surface_container_low"/>
                    </androidx.cardview.widget.CardView>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Chiến tranh và hòa bình"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/on_surface"
                        android:maxLines="2"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Leo Tolstoy"
                        android:textSize="14sp"
                        android:textColor="@color/on_surface_variant"/>
                </LinearLayout>

                <!-- Additional Books can be added similarly -->

            </GridLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Nav Bar -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/bottom_nav_bg"
        android:elevation="16dp"
        app:itemIconTint="@color/on_surface_variant"
        app:itemTextColor="@color/on_surface_variant"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:menu="@menu/bottom_nav_menu" />

</androidx.constraintlayout.widget.ConstraintLayout>